---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Clarive Studio — Design, Copy & Strategy for Conversions" description="We build focused websites for business owners who want more clarity, fewer revisions, and marketing pages that feel calm yet persuasive.">
  <div class="scroll-progress" id="scrollProgress"></div>

  <header>
    <div class="container">
      <nav>
        <a href="#" class="logo">
          <img src="/assets/images/logo.png" alt="Clarive Studio" class="logo-img" loading="eager">
        </a>
        <ul class="nav-menu" id="nav-menu">
          <li><a href="#services">Services</a></li>
          <li><a href="#portfolio">Work</a></li>
          <li><a href="#process">Process</a></li>
          <li><a href="#pricing">Pricing</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
        <a href="#contact" class="nav-cta">
          Book a Call
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <button class="hamburger" id="hamburger" aria-label="Toggle menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-grid-pattern"></div>
      <div class="container hero-inner">
        <div class="hero-content">
          <div class="hero-badge">
            <span class="hero-badge-dot"></span>
            Available for new projects
          </div>
          <h1 class="hero-title">
            You don't need a prettier website.<br>
            You need one that <span class="highlight">brings you customers.</span>
          </h1>
          <p class="hero-description">
            We build focused sites for owners who want more clarity, fewer revisions, and marketing pages that feel calm yet persuasive. Design + Copy + Strategy, all under one roof.
          </p>
          <div class="hero-actions">
            <a href="#contact" class="btn-primary">
              Start Your Project
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <a href="#portfolio" class="btn-secondary">
              See Our Work
            </a>
          </div>
          <div class="hero-stats">
            <div class="stat">
              <div class="stat-number">50+</div>
              <div class="stat-label">Projects Delivered</div>
            </div>
            <div class="stat">
              <div class="stat-number">3+</div>
              <div class="stat-label">Years Experience</div>
            </div>
            <div class="stat">
              <div class="stat-number">98%</div>
              <div class="stat-label">Client Satisfaction</div>
            </div>
          </div>
        </div>
        <div class="hero-visual">
          <div class="hero-card">
            <div class="hero-card-header">
              <div class="hero-card-dots">
                <span class="hero-card-dot"></span>
                <span class="hero-card-dot"></span>
                <span class="hero-card-dot"></span>
              </div>
              <span class="hero-card-url">yourwebsite.com</span>
            </div>
            <div class="hero-card-content">
              <div class="hero-card-line"></div>
              <div class="hero-card-line"></div>
              <div class="hero-card-line"></div>
              <div class="hero-card-line"></div>
              <div class="hero-card-btn">Get Started</div>
            </div>
          </div>
          <div class="floating-badge floating-badge-1">
            <div class="floating-badge-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            </div>
            <div class="floating-badge-text">
              <div class="floating-badge-number">+240%</div>
              <div class="floating-badge-label">Conversion Rate</div>
            </div>
          </div>
          <div class="floating-badge floating-badge-2">
            <div class="floating-badge-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
              </svg>
            </div>
            <div class="floating-badge-text">
              <div class="floating-badge-number">7 Days</div>
              <div class="floating-badge-label">Avg. Delivery</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="trusted-by">
      <div class="container">
        <p class="trusted-by-label">Trusted by forward-thinking businesses</p>
        <div class="trusted-by-logos">
          <span class="trusted-logo">TechFlow</span>
          <span class="trusted-logo">Brightline</span>
          <span class="trusted-logo">Vertex</span>
          <span class="trusted-logo">Nova</span>
          <span class="trusted-logo">Summit</span>
          <span class="trusted-logo">Apex</span>
        </div>
      </div>
    </section>

    <section class="problem-solution">
      <div class="container">
        <div class="problem-solution-grid">
          <div class="problem-card animate-on-scroll">
            <div class="card-header">
              <div class="card-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M15 9l-6 6M9 9l6 6"/>
                </svg>
              </div>
              <h3 class="card-title">The Problem</h3>
            </div>
            <p class="card-description">
              Too many websites are pretty and empty. They look great in design mockups but don't generate a single customer. Designers hand you a beautiful template and ask you to "fill in the content" — then wonder why the site doesn't convert.
            </p>
          </div>
          <div class="solution-card animate-on-scroll delay-1">
            <div class="card-header">
              <div class="card-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M9 12l2 2 4-4"/>
                </svg>
              </div>
              <h3 class="card-title">Our Solution</h3>
            </div>
            <p class="card-description">
              Everything your website needs, under one roof. We research your customers, write every word, and build the design — all in lockstep. No guessing, no handoff problems, no "that's not my department."
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="services" id="services">
      <div class="container">
        <div class="section-header animate-on-scroll">
          <span class="section-label">What We Do</span>
          <h2 class="section-title">Services built for conversions</h2>
          <p class="section-subtitle">
            Every service includes strategy, copywriting, and design — working together from day one.
          </p>
        </div>
        <div class="services-grid">
          <div class="service-card animate-on-scroll">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <path d="M8 21h8M12 17v4"/>
              </svg>
            </div>
            <h3 class="service-title">Website Design & Copy</h3>
            <p class="service-description">The full package: customer research, conversion copywriting, and design built around your message. No template, no guessing.</p>
            <span class="service-tag">Small Business &bull; Consultants &bull; Clinics</span>
          </div>
          <div class="service-card animate-on-scroll delay-1">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
            <h3 class="service-title">Portfolio Websites</h3>
            <p class="service-description">For creative professionals who want the right clients to notice. We write, design, and build to make your work shine.</p>
            <span class="service-tag">Photographers &bull; Architects &bull; Coaches</span>
          </div>
          <div class="service-card animate-on-scroll delay-2">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            </div>
            <h3 class="service-title">Sales & Landing Pages</h3>
            <p class="service-description">One page, one goal, one action. Designed and written for conversions — fast to build, easy to track, impossible to ignore.</p>
            <span class="service-tag">Course Creators &bull; Coaches &bull; Launches</span>
          </div>
          <div class="service-card animate-on-scroll delay-1">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 19l7-7 3 3-7 7-3-3z"/>
                <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/>
                <path d="M2 2l7.586 7.586"/>
                <circle cx="11" cy="11" r="2"/>
              </svg>
            </div>
            <h3 class="service-title">Blogs & Personal Sites</h3>
            <p class="service-description">Clean, easy-to-read spaces for writers and creators. Designed to keep readers engaged and coming back for more.</p>
            <span class="service-tag">Writers &bull; Journalists &bull; Creators</span>
          </div>
          <div class="service-card animate-on-scroll delay-2">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 3a2.85 2.85 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/>
              </svg>
            </div>
            <h3 class="service-title">Website Copywriting</h3>
            <p class="service-description">Conversion copy for existing sites. Headlines, CTAs, and body text based on real buyer personas — not generic templates.</p>
            <span class="service-tag">Teams &bull; Existing Sites &bull; Refresh</span>
          </div>
          <div class="service-card animate-on-scroll delay-3">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="9" cy="21" r="1"/>
                <circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
              </svg>
            </div>
            <h3 class="service-title">eCommerce</h3>
            <p class="service-description">Sell better with clear product paths, persuasive copy, and checkout UX that doesn't make people think twice.</p>
            <span class="service-tag">Product Brands &bull; Makers &bull; Retail</span>
          </div>
        </div>
      </div>
    </section>

    <section class="portfolio" id="portfolio">
      <div class="container">
        <div class="section-header animate-on-scroll">
          <span class="section-label">Our Work</span>
          <h2 class="section-title">Results that speak for themselves</h2>
          <p class="section-subtitle">
            A selection of projects where strategy, copy, and design worked together to drive real business outcomes.
          </p>
        </div>
        <div class="portfolio-grid">
          <div class="portfolio-card animate-on-scroll">
            <div class="portfolio-preview">
              <div class="portfolio-preview-bg"></div>
              <div class="portfolio-overlay">
                <span class="portfolio-view-btn">View Case Study</span>
              </div>
            </div>
            <div class="portfolio-content">
              <span class="portfolio-tag">eCommerce</span>
              <h3 class="portfolio-title">Artisan Coffee Co.</h3>
              <p class="portfolio-client">Premium coffee subscription brand</p>
              <div class="portfolio-result">
                <span class="portfolio-result-number">+340%</span>
                <span class="portfolio-result-text">increase in monthly subscriptions</span>
              </div>
            </div>
          </div>
          <div class="portfolio-card animate-on-scroll delay-1">
            <div class="portfolio-preview">
              <div class="portfolio-preview-bg"></div>
              <div class="portfolio-overlay">
                <span class="portfolio-view-btn">View Case Study</span>
              </div>
            </div>
            <div class="portfolio-content">
              <span class="portfolio-tag">SaaS</span>
              <h3 class="portfolio-title">Velocity Analytics</h3>
              <p class="portfolio-client">Business intelligence platform</p>
              <div class="portfolio-result">
                <span class="portfolio-result-number">+180%</span>
                <span class="portfolio-result-text">more demo requests</span>
              </div>
            </div>
          </div>
          <div class="portfolio-card animate-on-scroll delay-2">
            <div class="portfolio-preview">
              <div class="portfolio-preview-bg"></div>
              <div class="portfolio-overlay">
                <span class="portfolio-view-btn">View Case Study</span>
              </div>
            </div>
            <div class="portfolio-content">
              <span class="portfolio-tag">Coaching</span>
              <h3 class="portfolio-title">Mindset Academy</h3>
              <p class="portfolio-client">Executive coaching program</p>
              <div class="portfolio-result">
                <span class="portfolio-result-number">+95%</span>
                <span class="portfolio-result-text">conversion rate improvement</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="process" id="process">
      <div class="container">
        <div class="section-header animate-on-scroll">
          <span class="section-label">Our Process</span>
          <h2 class="section-title">How we work</h2>
          <p class="section-subtitle">
            A simple, transparent process built around your goals. No surprises, no confusion — just results.
          </p>
        </div>
        <div class="process-grid">
          <div class="process-step animate-on-scroll">
            <div class="process-step-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <div class="step-number">01</div>
            <h3 class="step-title">We Learn About Your Customer</h3>
            <p class="step-description">We ask the questions most designers miss: customer fears, hesitations, and the exact language they use about their problem.</p>
          </div>
          <div class="process-step animate-on-scroll delay-1">
            <div class="process-step-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9-9z"/>
              </svg>
            </div>
            <div class="step-number">02</div>
            <h3 class="step-title">We Write Everything First</h3>
            <p class="step-description">Headlines, subheadlines, CTAs — all copy approved before design begins. This separates a converting site from a nice-looking one.</p>
          </div>
          <div class="process-step animate-on-scroll delay-2">
            <div class="process-step-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            </div>
            <div class="step-number">03</div>
            <h3 class="step-title">We Design Around the Copy</h3>
            <p class="step-description">Every visual decision serves what the copy needs to say. Layout, hierarchy, and UX are built purposefully — not decoratively.</p>
          </div>
          <div class="process-step animate-on-scroll delay-3">
            <div class="process-step-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <div class="step-number">04</div>
            <h3 class="step-title">We Deliver with Full Clarity</h3>
            <p class="step-description">Delivery includes a 1-on-1 walkthrough: what works, why it's structured this way, and how visitors will think as they read.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="team" id="team">
      <div class="container">
        <div class="section-header animate-on-scroll">
          <span class="section-label">Meet the Team</span>
          <h2 class="section-title">Two people. Both obsessed with websites that actually work.</h2>
        </div>
        <div class="team-grid">
          <div class="team-card animate-on-scroll">
            <div class="team-avatar">AR</div>
            <h3 class="team-name">Abdul Rahman</h3>
            <p class="team-role">Co-founder &bull; Web Designer &bull; Automation Expert</p>
            <p class="team-bio">Builds every site with a focus on results over awards. Particular about how sites look and even more particular about how they convert.</p>
            <div class="team-social">
              <a href="#" class="team-social-link" aria-label="LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                  <rect x="2" y="9" width="4" height="12"/>
                  <circle cx="4" cy="4" r="2"/>
                </svg>
              </a>
              <a href="#" class="team-social-link" aria-label="Twitter">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 4l11.733 16h4.267l-11.733 -16z"/>
                  <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"/>
                </svg>
              </a>
            </div>
          </div>
          <div class="team-card animate-on-scroll delay-1">
            <div class="team-avatar">RI</div>
            <h3 class="team-name">Riyan Immack</h3>
            <p class="team-role">Co-founder &bull; Copywriter &bull; Client Strategist</p>
            <p class="team-bio">First point of contact. Writes every headline, paragraph, and CTA around customer fears and desires. Fixes the biggest reason sites fail: not asking the right questions first.</p>
            <div class="team-social">
              <a href="#" class="team-social-link" aria-label="LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                  <rect x="2" y="9" width="4" height="12"/>
                  <circle cx="4" cy="4" r="2"/>
                </svg>
              </a>
              <a href="#" class="team-social-link" aria-label="Twitter">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 4l11.733 16h4.267l-11.733 -16z"/>
                  <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
        <div class="team-quote animate-on-scroll">
          <p>"You work directly with us. No juniors, no middleman, no gatekeepers. Just two people who care about your results as much as you do."</p>
        </div>
      </div>
    </section>

    <section class="pricing" id="pricing">
      <div class="container">
        <div class="section-header animate-on-scroll">
          <span class="section-label">Pricing</span>
          <h2 class="section-title">Transparent pricing, no surprises</h2>
          <p class="section-subtitle">
            Choose the package that fits your needs. All packages include strategy, copywriting, design, and post-launch support.
          </p>
        </div>
        <div class="pricing-grid">
          <div class="pricing-card animate-on-scroll">
            <h3 class="pricing-name">Clarity</h3>
            <p class="pricing-pages">Up to 4 pages</p>
            <div class="pricing-delivery">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
              </svg>
              7-10 business days
            </div>
            <ul class="pricing-features">
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                Customer research & strategy
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                Conversion-focused copywriting
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                Mobile-responsive design
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                1 revision round
              </li>
            </ul>
            <a href="#contact" class="pricing-cta secondary">Get Started</a>
          </div>
          <div class="pricing-card featured animate-on-scroll delay-1">
            <span class="pricing-badge">Most Popular</span>
            <h3 class="pricing-name">Conversion</h3>
            <p class="pricing-pages">Up to 7 pages</p>
            <div class="pricing-delivery">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
              </svg>
              14-18 business days
            </div>
            <ul class="pricing-features">
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                Everything in Clarity
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                Landing/sales page included
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                SEO foundation setup
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                2 revision rounds
              </li>
            </ul>
            <a href="#contact" class="pricing-cta primary">Get Started</a>
          </div>
          <div class="pricing-card animate-on-scroll delay-2">
            <h3 class="pricing-name">Growth</h3>
            <p class="pricing-pages">Up to 10 pages + SEO</p>
            <div class="pricing-delivery">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
              </svg>
              21-28 business days
            </div>
            <ul class="pricing-features">
              <li>
